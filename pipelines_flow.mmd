flowchart TB
  %% STYLES
  classDef source    fill:#3b82f6,stroke:#1e40af,stroke-width:2,color:#ffffff,font-weight:bold;
  classDef db        fill:#059669,stroke:#047857,stroke-width:2,color:#ffffff,font-weight:bold;
  classDef service   fill:#8b5cf6,stroke:#6d28d9,stroke-width:2,color:#ffffff,font-weight:bold;
  classDef model     fill:#ec4899,stroke:#be185d,stroke-width:2,color:#ffffff,font-weight:bold;
  classDef orch      fill:#f59e0b,stroke:#d97706,stroke-width:2,color:#ffffff,font-weight:bold;

  %% ROW 1 — ORCHESTRATION
  ORCH["🎯 run_daily_pipeline.py<br/><i>Daily Orchestrator</i>"]:::orch

  %% ROW 2 — LIVE SOURCE
  subgraph L1["Data Source"]
    direction TB
    SRC["📡 Theta Data Terminal<br/><i>127.0.0.1:25503</i>"]:::source
  end

  %% ROW 3 — INGESTION
  subgraph L2["Ingestion Jobs"]
    direction LR
    EOD["📊 eod_prices_td.py<br/><i>Fetch EOD Prices</i>"]:::service
    SNAP["📋 td_options_snapshot.py<br/><i>Fetch Options Chain</i>"]:::service
  end

  %% ROW 4 — STORAGE
  subgraph L3["Live Databases"]
    direction LR
    DB_LIVE["💾 DUCKDB_PATH_LIVE<br/><i>EOD Prices + Live Signals</i>"]:::db
    DB_OPT["💾 DUCKDB_PATH_LIVE_OPTIONS<br/><i>Options Chain Snapshots</i>"]:::db
  end

  %% ROW 5 — HISTORICAL FEATURES (pre-built from CBOE data via notebooks)
  subgraph L4["Historical Feature Store"]
    direction TB
    DB_HIST["💾 DUCKDB_PATH_HIST<br/><i>features_spy_latest<br/>(CBOE historical + options-derived)</i>"]:::db
  end

  %% ROW 6 — TRAINING & INFERENCE
  subgraph L5["Models & Signals"]
    direction LR
    TRAIN["⚙️ ml_signal_engine.py<br/><i>Walk-Forward Retrain</i>"]:::service
    ENS["🤖 ENSEMBLE_ARTIFACTS_DIR<br/><i>Trained SPY Models</i>"]:::model
    INF["🔮 ml_signal_inference.py<br/><i>Generate Live Signal</i>"]:::service
  end

  %% ROW 7 — NOTIFICATION
  subgraph L6["Notification"]
    direction TB
    EMAIL["✉️ notify_email.py<br/><i>Email Signal Report</i>"]:::service
  end

  %% SEQUENTIAL FLOW (TOP -> BOTTOM)

  %% Orchestrator triggers pipeline steps in order
  ORCH --> SRC
  ORCH --> EOD
  ORCH --> SNAP
  ORCH --> TRAIN
  ORCH --> INF
  ORCH --> EMAIL

  %% Source -> Ingestion
  SRC --> EOD
  SRC --> SNAP

  %% Ingestion -> Live Databases
  EOD --> DB_LIVE
  SNAP --> DB_OPT

  %% Historical features -> Training and Inference
  DB_HIST --> TRAIN
  DB_HIST --> INF

  %% Training -> Ensemble Artifacts -> Inference
  TRAIN --> ENS
  ENS --> INF

  %% Inference writes signal back to live DB
  INF --> DB_LIVE

  %% Live signals -> Email
  DB_LIVE --> EMAIL
